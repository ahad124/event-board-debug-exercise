# Copy this file to ".env" and adjust values before running `docker-compose up`.
# docker-compose automatically loads the root .env file.

# SQL Server "sa" password (must meet SQL Server complexity requirements)
MSSQL_SA_PASSWORD=EventBoard_Db!Passw0rd

# JWT signing key (must be at least 32 bytes/characters)
JWT_KEY=ThisIsADevelopmentSecretKeyThatIsAtLeast32BytesLong!

# OpenWeather API key. Get a free key at https://openweathermap.org/api
# If left blank, the weather panel gracefully shows "forecast unavailable".
OPENWEATHER_API_KEY=
